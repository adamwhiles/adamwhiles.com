{
  "routes": [
    {
      "route": "/blog/*",
      "rewrite": "/blog/*"
    }
  ],
  "navigationFallback": {
    "rewrite": "/404",
    "exclude": ["/assets/*", "/*.css", "/*.js", "/*.svg", "/*.png", "/*.ico"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
