{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/_astro/*", "/*.css", "/*.js", "/*.svg", "/*.png", "/*.ico"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
