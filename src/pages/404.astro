---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Adam Whiles">
  <section class="max-w-5xl mx-auto px-6 pt-32 pb-24 text-center">
    <p class="font-mono text-6xl font-bold mb-6" style="color: var(--color-accent);">404</p>
    <p class="font-mono text-lg mb-2" style="color: var(--color-text);">page not found</p>
    <p class="font-mono text-sm mb-10" style="color: var(--color-muted);">
      > error: the path you requested does not exist
    </p>
    <a href="/" class="font-mono text-sm hover:opacity-80" style="color: var(--color-accent);">← go home</a>
  </section>
</BaseLayout>
